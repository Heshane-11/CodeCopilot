# ============================================================================
# CodeCopilot Configuration
# Copy this file to .env and fill in your values
# ============================================================================

# DATABASE & CACHE
# ============================================================================
# PostgreSQL connection (used for state management and runs history)
DATABASE_URL=postgresql+asyncpg://assistant:assistant@localhost:5432/assistant

# Redis connection (used for session cache and job queue)
REDIS_URL=redis://localhost:6379/0

# MODELS & API KEYS
# ============================================================================
# Choose ONE or MORE model providers and add their API keys:

# OpenAI (GPT-4, GPT-3.5)
OPENAI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Default model to use (if multiple keys provided)
# Examples: claude-3-5-sonnet, gpt-4, gemini-2.5-flash
ROUTING_DEFAULT_MODEL=

# WORKSPACE & EXECUTION
# ============================================================================
# Default workspace/repository path for analysis
WORKSPACE_ROOT=/tmp/workspace

# Max iterations for agent loop before stopping
MAX_AGENT_ITERATIONS=10

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# SANDBOX SECURITY
# ============================================================================
# Run tools in isolated Docker container for safety
SANDBOX_ENABLED=true
SANDBOX_BACKEND=docker
SANDBOX_IMAGE=coding-assistant-sandbox:local
SANDBOX_MEMORY_MB=512
SANDBOX_CPU_COUNT=1.0
SANDBOX_TIMEOUT_SECONDS=300
SANDBOX_NETWORK_ENABLED=false

# CODE INDEXING & RETRIEVAL
# ============================================================================
# Model for embeddings (for semantic code search)
EMBEDDING_MODEL=

# Embedding vector dimensions
EMBEDDING_DIMENSIONS=384

# Automatically index repository on startup
REPO_AUTO_INDEX=true

# Max number of files to index
REPO_MAX_FILES=500

OTEL_ENABLED=true
OTEL_SERVICE_NAME=coding-assistant
OTEL_EXPORTER=console
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
METRICS_ENABLED=true

AUTH_REQUIRED=false
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=1440
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

MCP_ENABLED=true
MCP_USE_STUBS=true
MCP_AGENT_TOOLS_ENABLED=false

CHAT_API_BASE_URL=http://127.0.0.1:8000
# CHAT_API_TOKEN=
CHAT_POLL_INTERVAL_SECONDS=1.0
CHAT_RUN_TIMEOUT_SECONDS=300
# MCP_GITHUB_COMMAND=npx -y @modelcontextprotocol/server-github
