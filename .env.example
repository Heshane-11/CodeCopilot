DATABASE_URL=postgresql+asyncpg://assistant:assistant@localhost:5432/assistant
REDIS_URL=redis://localhost:6379/0
ROUTING_CONFIG_PATH=routing.config.json
ROUTING_DEFAULT_MODEL=
# Deprecated alias for ROUTING_DEFAULT_MODEL:
# LITELLM_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Google Gemini (either name works; LiteLLM uses GEMINI_API_KEY / GOOGLE_API_KEY)
GEMINI_API_KEY=
# GOOGLE_API_KEY=
# Use Gemini for all tiers: ROUTING_CONFIG_PATH=routing.config.gemini.json
# Or single model: ROUTING_DEFAULT_MODEL=gemini/gemini-2.5-flash
WORKSPACE_ROOT=/tmp/workspace
MAX_AGENT_ITERATIONS=10
LOG_LEVEL=INFO

SANDBOX_ENABLED=true
SANDBOX_BACKEND=docker
SANDBOX_IMAGE=coding-assistant-sandbox:local
SANDBOX_MEMORY_MB=512
SANDBOX_CPU_COUNT=1.0
SANDBOX_TIMEOUT_SECONDS=300
SANDBOX_NETWORK_ENABLED=false

EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=384
REPO_AUTO_INDEX=true
REPO_MAX_FILES=500

OTEL_ENABLED=true
OTEL_SERVICE_NAME=coding-assistant
OTEL_EXPORTER=console
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
METRICS_ENABLED=true

AUTH_REQUIRED=false
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=1440
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

MCP_ENABLED=true
MCP_USE_STUBS=true
MCP_AGENT_TOOLS_ENABLED=false

CHAT_API_BASE_URL=http://127.0.0.1:8000
# CHAT_API_TOKEN=
CHAT_POLL_INTERVAL_SECONDS=1.0
CHAT_RUN_TIMEOUT_SECONDS=300
# MCP_GITHUB_COMMAND=npx -y @modelcontextprotocol/server-github
